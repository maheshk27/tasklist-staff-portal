{
  "name": "staff-portal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --mode development-local",
    "dev:dev": "vite --mode development",
    "dev:staging": "vite --mode staging",
